# Copy the values below into your shell (or a local .env.test, loaded manually —
# vitest does not auto-load dotenv files in this project) before running the
# DB-integration tests under tests/*.test.ts. NEVER commit an actual .env* file.

# --- Direct Postgres connection for tests/*.test.ts ---------------------------
# These tests call reserve_tickets()/confirm_order_paid()/expire_stale_orders()/
# promote_waitlist() directly over a raw Postgres connection (via the `pg`
# driver), not through Supabase's PostgREST/HTTP layer — so this must be the
# DIRECT Postgres port, not the API gateway port.
#
# `supabase start` (or `supabase status` on an already-running stack) prints
# this connection string. Default local values:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Optional: cap how many simulated concurrent buyers open a real connection at
# once during the 500-buyer oversell test (default 40). Raise this only if
# your test Postgres is configured with enough `max_connections` headroom.
DB_TEST_MAX_CONCURRENCY=40
