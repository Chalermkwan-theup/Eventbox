# Copy this file to .env.local (Next.js) and fill in real values.
# NEVER commit an actual .env* file — see .gitignore.

# --- Supabase --------------------------------------------------------------
# Project URL and anon key are safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key bypasses Row Level Security entirely. Server-only — used
# by the Stripe webhook handler (lib/supabase/admin.ts). Never expose to the
# client, never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe ------------------------------------------------------------------
# Secret key used to create PaymentIntents (PromptPay) and issue refunds.
STRIPE_SECRET_KEY=sk_test_xxx

# Signing secret for the /api/webhooks/stripe endpoint (from `stripe listen`
# locally, or the endpoint's signing secret in the Stripe Dashboard).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Publishable key used client-side by components/payment-panel.tsx
# (loadStripe) to confirm the PromptPay PaymentIntent and render its QR.
# Safe to expose to the browser — NEXT_PUBLIC_* by design.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
